# -------------------------------------------------------------------
# Canonical redirects (force HTTPS + www in ONE hop)
# -------------------------------------------------------------------
RewriteEngine On

# If not HTTPS OR not on www, redirect to https://www.mrlookwedding.com
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.mrlookwedding\.com$ [NC]
RewriteRule ^ https://www.mrlookwedding.com%{REQUEST_URI} [L,R=301]

# -------------------------------------------------------------------
# Performance: compression + long-lived caching for static assets
# -------------------------------------------------------------------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(avif|webp|jpe?g|png|svg|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
